{
  "name": "@anvio/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "anvio": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/main.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@anvio/core": "workspace:*",
    "@anvio/platform": "workspace:*",
    "@anvio/workspace": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
