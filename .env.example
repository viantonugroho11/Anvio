# Anvio Local Environment (Optional — Level 1 needs none of this)

# Workspace path (default: ./workspace)
ANVIO_WORKSPACE=./workspace

# Model provider (optional — mock mode without any key)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Claude Code runtime OAuth (Pro/Max subscription — not API key billing)
# anvio setup-token --claude
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-your-token-here
# OPENAI_API_KEY=sk-your-key-here
# GEMINI_API_KEY=your-gemini-key
# GOOGLE_API_KEY=your-gemini-key
# OPENROUTER_API_KEY=sk-or-your-key-here
# OPENROUTER_REFERER=https://your-app.example
# OPENROUTER_APP_NAME=Anvio
# OpenAI-compatible providers (set any that you use)
# DEEPSEEK_API_KEY=sk-your-key-here
# GROQ_API_KEY=gsk_your-key-here
# MISTRAL_API_KEY=your-key-here
# TOGETHER_API_KEY=your-key-here
# XAI_API_KEY=your-key-here
# FIREWORKS_API_KEY=your-key-here
# MOONSHOT_API_KEY=your-key-here
# CEREBRAS_API_KEY=your-key-here
# SAMBANOVA_API_KEY=your-key-here
# PERPLEXITY_API_KEY=pplx-your-key-here
# COHERE_API_KEY=your-key-here
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_ENABLED=true

# Custom OpenAI-compatible endpoint (use with provider: custom in agent YAML)
# CUSTOM_API_KEY=your-key-here

# Credential pools (Advanced OS — optional)
# Used when storing encrypted API keys via `anvio credentials add`
ANVIO_CREDENTIALS_PASSPHRASE=change-me-in-production

# MCP integrations (optional — enable servers in workspace/mcp/servers.yaml)
# GITHUB_TOKEN=ghp_your-token-here

# --- Level 2+ only ---

# API
API_PORT=3000

# Gateway
GATEWAY_PORT=3001
API_URL=http://localhost:3000

# ACP editor integration (optional)
# ACP_PORT=8765

# Auth (only when workspace/anvio.yaml has auth.enabled: true)
JWT_SECRET=change-me-in-production

# PostgreSQL (Level 3 — optional)
# DATABASE_URL=postgresql://anvio:anvio@localhost:5432/anvio

# Redis (Level 3 — optional)
# REDIS_URL=redis://localhost:6379

# NATS (Level 3 — set events.provider: nats in anvio.yaml)
# NATS_URL=nats://localhost:4222

# Observability (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
